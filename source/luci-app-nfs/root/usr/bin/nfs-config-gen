#!/bin/sh
. /lib/functions.sh

NFS_CONF=/etc/nfs.conf
EXPORTS_FILE=/etc/exports
NFS_D=/var/lib/nfs
RPC_PIPEFS_D=/var/lib/nfs/rpc_pipefs

log() {
    logger -t "nfs-config-gen" "$1"
    echo "$1"
}

write_share() {
    local cfg="$1"
    local path clients options
    config_get path "$cfg" path
    config_get clients "$cfg" clients "*"
    config_get options "$cfg" options "rw,sync,no_subtree_check"
    if [ -n "$path" ]; then
        log "Adding export: $path $clients($options)"
        echo "$path $clients($options)" >> "$EXPORTS_FILE"
    fi
}

config_load nfs
config_get_bool enabled globals enabled 0

if [ "$enabled" -eq 0 ]; then
    log "NFS server is disabled in UCI. Stopping service."
    /etc/init.d/nfsd stop 2>/dev/null
    exit 0
fi

log "Generating NFS configurations..."

# Ensure directories exist
mkdir -p "$NFS_D" "$RPC_PIPEFS_D"

# Fix for native script "Resource busy" error
# We check by filesystem type because /var is a symlink to /tmp on this system,
# causing the native script's path-based grep to fail and try to double-mount.
grep -q "nfsd" /proc/mounts || mount -t nfsd nfsd /proc/fs/nfsd 2>/dev/null
grep -q "rpc_pipefs" /proc/mounts || mount -t rpc_pipefs sunrpc "$RPC_PIPEFS_D" 2>/dev/null

# Generate /etc/exports
echo "# Generated from UCI /etc/config/nfs" > "$EXPORTS_FILE"
config_foreach write_share share

# Generate /etc/nfs.conf
config_get threads globals threads 16
config_get port globals port 2049
config_get_bool nfs_v3 globals nfs_v3 1
config_get_bool nfs_v4 globals nfs_v4 1
config_get_bool udp globals udp 0
config_get_bool tcp globals tcp 1

log "Updating $NFS_CONF (v3=$nfs_v3, v4=$nfs_v4, port=$port, threads=$threads)"

cat > "$NFS_CONF" <<CONF
[nfsd]
threads=$threads
port=$port
udp=$( [ "$udp" -eq 1 ] && echo "y" || echo "n" )
tcp=$( [ "$tcp" -eq 1 ] && echo "y" || echo "n" )
vers3=$( [ "$nfs_v3" -eq 1 ] && echo "y" || echo "n" )
vers4=$( [ "$nfs_v4" -eq 1 ] && echo "y" || echo "n" )
CONF

# Ensure rpcbind is started
if ! /etc/init.d/rpcbind status | grep -q "running"; then
    log "Starting rpcbind..."
    /etc/init.d/rpcbind enable 2>/dev/null
    /etc/init.d/rpcbind start
fi


