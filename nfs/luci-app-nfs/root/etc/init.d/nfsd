#!/bin/sh /etc/rc.common
# Unified NFS init script for OpenWrt (UCI managed)
# Copyright (C) 2026 Gemini CLI

START=99
STOP=60
USE_PROCD=1

NFS_D=/var/lib/nfs
LOCK_D=/var/lib/nfs/sm
RPC_PIPEFS_D=/var/lib/nfs/rpc_pipefs

write_share() {
	local cfg="$1"
	local path clients options
	config_get path "$cfg" path
	config_get clients "$cfg" clients "*"
	config_get options "$cfg" options "rw,sync,no_subtree_check"
	[ -n "$path" ] && echo "$path $clients($options)" >> /etc/exports
}

start_service() {
	config_load nfs
	config_get_bool enabled globals enabled 0
	[ "$enabled" -eq 0 ] && return

	logger -t "nfsd" -p notice "Starting NFS server (UCI managed)"

	# Generate /etc/exports
	echo "# Generated from UCI /etc/config/nfs" > /etc/exports
	config_foreach write_share share

	# Ensure directories exist
	mkdir -p "$NFS_D" "$LOCK_D" "$RPC_PIPEFS_D"
	chown nfs:nfs "$NFS_D"
	touch "$NFS_D/rmtab"

	# Kernel modules and mounts
	grep -q /proc/fs/nfsd /proc/mounts || mount -t nfsd nfsd /proc/fs/nfsd
	
	config_get_bool nfs_v3 globals nfs_v3 1
	config_get_bool nfs_v4 globals nfs_v4 1

	if [ "$nfs_v3" -eq 1 ]; then
		sysctl -w fs.nfs.nlm_tcpport=32777 fs.nfs.nlm_udpport=32777 > /dev/null
		procd_open_instance "statd"
		procd_set_param command /usr/sbin/rpc.statd -p 32778 -o 32779 -F
		procd_set_param respawn
		procd_close_instance
	fi

	if [ "$nfs_v4" -eq 1 ]; then
		grep -q "$RPC_PIPEFS_D" /proc/mounts || mount -t rpc_pipefs sunrpc "$RPC_PIPEFS_D"
		
		[ -x /usr/sbin/nfsv4.exportd ] && {
			procd_open_instance "exportd"
			procd_set_param command /usr/sbin/nfsv4.exportd -f -L
			procd_set_param respawn
			procd_close_instance
		}

		[ -x /usr/sbin/rpc.idmapd ] && {
			procd_open_instance "idmapd"
			procd_set_param command /usr/sbin/rpc.idmapd -f
			procd_set_param respawn
			procd_close_instance
		}

		[ -x /usr/sbin/nfsdcld ] && {
			procd_open_instance "nfsdcld"
			procd_set_param command /usr/sbin/nfsdcld
			procd_close_instance
		}
	fi

	# Reload exports
	/usr/sbin/exportfs -r

	# Start nfsd
	local nfsd_args=""
	[ "$nfs_v3" -eq 0 ] && nfsd_args="$nfsd_args --no-nfs-version 3"
	if [ "$nfs_v4" -eq 1 ]; then
		nfsd_args="$nfsd_args -V 4.0"
	else
		nfsd_args="$nfsd_args --no-nfs-version 4 --no-nfs-version 4.1 --no-nfs-version 4.2"
	fi

	procd_open_instance "nfsd"
	# Use nfsdctl if available, fallback to rpc.nfsd
	if [ -x /usr/sbin/nfsdctl ]; then
		procd_set_param command /usr/sbin/rpc.nfsd $nfsd_args
	else
		procd_set_param command /usr/sbin/rpc.nfsd $nfsd_args
	fi
	procd_close_instance

	if [ "$nfs_v3" -eq 1 ]; then
		procd_open_instance "mountd"
		procd_set_param command /usr/sbin/rpc.mountd -p 32780 -F
		procd_set_param respawn
		procd_close_instance
	fi
}

stop_service() {
	/usr/sbin/rpc.nfsd 0 2>/dev/null
	/usr/sbin/exportfs -au
	/usr/sbin/exportfs -f
	killall nfsdcld 2>/dev/null
	
	grep -q "$RPC_PIPEFS_D" /proc/mounts && umount "$RPC_PIPEFS_D"
	grep -q /proc/fs/nfsd /proc/mounts && umount /proc/fs/nfsd
}

reload_service() {
	echo "# Generated from UCI /etc/config/nfs" > /etc/exports
	config_load nfs
	config_foreach write_share share
	/usr/sbin/exportfs -r
}

service_triggers() {
	procd_add_reload_trigger "nfs"
}
